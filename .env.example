# ==========================================
# 应用配置 / Application Config
# ==========================================
NODE_ENV=production
PORT=9000
API_KEY=your_api_key_here
LOG_LEVEL=info

# ==========================================
# 数据库配置（AzerothCore，只读连接）
# Database Config (AzerothCore, read-only)
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=acore
DB_PASS=acore
DB_AUTH=acore_auth
DB_CHARACTERS=acore_characters
DB_WORLD=acore_world

# ==========================================
# Redis 配置（热点数据缓存）
# Redis Config (hot data cache)
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_EXPIRE_TIME=300

# ==========================================
# CORS / iframe 配置
# CORS / iframe Config
# ==========================================
ALLOWED_ORIGINS=https://your-wordpress-site.com

# ==========================================
# 外部链接 / External Links
# ==========================================
SITE_URL=http://localhost/web-api/
ARMORY_BASE_URL=http://lokta.cn:48733
SERVER_NAME=阿拉希
