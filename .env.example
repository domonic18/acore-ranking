# ==========================================
# 应用配置 / Application Config
# ==========================================
NODE_ENV=production
PORT=9000
LOG_LEVEL=info

# ==========================================
# 数据库配置（AzerothCore，只读连接）
# 使用连接串，包含 host/port/user/pass
# Database Config (AzerothCore, read-only)
# ==========================================
DB_URL=mysql://user:pass@host:port
DB_AUTH=acore_auth
DB_CHARACTERS=acore_characters
DB_WORLD=acore_world

# ==========================================
# Redis 配置（热点数据缓存）
# 使用连接串，包含 host/port/password/db
# Redis Config (hot data cache)
# ==========================================
REDIS_URL=redis://:password@host:port/db
REDIS_EXPIRE_TIME=300

# ==========================================
# CORS / iframe 配置
# ==========================================
ALLOWED_ORIGINS=https://your-wordpress-site.com

# ==========================================
# Widget 在线人数小部件链接配置
# 构建时注入到前端代码中（Vite build-time）
# 修改后需要重新构建才能生效
# Widget iframe links — injected at build time
# ==========================================
VITE_WIDGET_DETAIL_URL=http://example.com/?page_id=135
VITE_WIDGET_ONLINE_URL=http://example.com/?page_id=1897

# ==========================================
# 外部资源地址 / External Asset URLs
# ==========================================
# 图标 CDN 地址，生产环境建议替换为自托管 CDN（如腾讯云 COS）
# 国内访问 Wowhead CDN 可能不稳定
VITE_ICON_BASE_URL=https://wow.zamimg.com/images/wow/icons/medium
VITE_AOWOW_BASE_URL=https://wowgaming.altervista.org/aowow

# ==========================================
# 最近成就显示数量
# Recent achievements display limit
# ==========================================
RECENT_ACHIEVEMENT_LIMIT=50
