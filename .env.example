# ==========================================
# 应用配置 / Application Config
# ==========================================
NODE_ENV=production
PORT=9000
LOG_LEVEL=info

# ==========================================
# 数据库配置（AzerothCore，只读连接）
# 支持连接串或分字段配置，连接串优先
# Database Config (AzerothCore, read-only)
# ==========================================
DB_URL=mysql://user:pass@host:port
DB_AUTH=acore_auth
DB_CHARACTERS=acore_characters
DB_WORLD=acore_world

# ==========================================
# Redis 配置（热点数据缓存）
# 支持连接串或分字段配置，连接串优先
# Redis Config (hot data cache)
# ==========================================
REDIS_URL=redis://:password@host:port/db
REDIS_EXPIRE_TIME=300

# ==========================================
# CORS / iframe 配置
# ==========================================
ALLOWED_ORIGINS=https://your-wordpress-site.com

# ==========================================
# 外部链接 / External Links
# ==========================================
SITE_URL=http://localhost/web-api/
ARMORY_BASE_URL=
SERVER_NAME=

# ==========================================
# Widget 在线人数小部件链接配置
# 在云函数控制台修改后即时生效
# Widget iframe links — hot-reload via env var
# ==========================================
WIDGET_DETAIL_URL=http://example.com/?page_id=135
WIDGET_ONLINE_URL=http://example.com/?page_id=1897
